---
import type { Project } from '../../data/projects';
import { createSlug } from '../../data/projects';

const { project } = Astro.props as { project: Project };
const slug = createSlug(project.title);
---

<article
  class="project-card flex h-full flex-col justify-between gap-4 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-4 transition hover:border-[var(--color-primary)]"
  data-cursor="hover"
>
  <div class="flex items-center justify-between text-xs uppercase tracking-[0.3em] text-[var(--color-muted)]">
    <span>{project.year}</span>
    <a href={`/projects/${slug}`} class="hover:text-[var(--color-primary)]">
      View
    </a>
  </div>
  <div>
    <h3 class="text-lg font-semibold leading-tight text-[var(--color-primary)]">{project.title}</h3>
    <p class="mt-3 text-sm leading-relaxed">{project.description}</p>
  </div>
  <div class="flex flex-wrap gap-2 text-xs uppercase tracking-[0.2em] text-[var(--color-muted)]">
    {project.techStack.map((tech) => (
      <span class="rounded-full border border-[var(--color-border)] px-3 py-1">{tech}</span>
    ))}
  </div>
  <div class="flex flex-wrap gap-4 text-xs uppercase tracking-[0.3em] text-[var(--color-muted)]">
    {project.demoUrl ? (
      <a href={project.demoUrl} target="_blank" rel="noreferrer" class="hover:text-[var(--color-primary)]">
        Live
      </a>
    ) : null}
    {project.repoUrl ? (
      <a href={project.repoUrl} target="_blank" rel="noreferrer" class="hover:text-[var(--color-primary)]">
        Repo
      </a>
    ) : null}
  </div>
</article>
